---
import '../styles/global.css';
import FireEffects from '../components/FireEffects.astro';
import statusData from '../data/status.json';

interface Props {
	title: string;
    description?: string;
    image?: string;
}

const { 
    title, 
    description = "👑 REALTRONO — El trono más peligroso del fútbol. ¿Cuánto durará el míster?",
    image = "/og-default.jpg"
} = Astro.props;

// Get current status level for theme
const currentLevel = statusData.status.level;
const themeClass = `level-${currentLevel}`;
---

<!doctype html>
<html lang="es" data-theme={themeClass} class="theme-transition">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
        
        <!-- Open Graph / Facebook -->
        <meta property="og:type" content="website" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={image} />

        <!-- Twitter -->
        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:title" content={title} />
        <meta property="twitter:description" content={description} />
        <meta property="twitter:image" content={image} />

		<title>{title}</title>

        <!-- Google Fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=VT323&family=Press+Start+2P&display=swap" rel="stylesheet">
	</head>
	<body class="bg-inferno-dark text-inferno min-h-screen font-mono">
        <FireEffects />
        <div class="scanlines"></div>
        
        <!-- HEADER CON MARCA REALTRONO -->
        <header class="sticky top-0 z-50 relative w-full border-b-2 border-inferno/60 bg-inferno-dark/95 backdrop-blur-sm">
            <div class="max-w-5xl mx-auto px-4 py-3 flex items-center justify-between">
                <!-- LOGO + MARCA -->
                <a href="/" class="flex items-center gap-3 group">
                    <span class="text-2xl group-hover:animate-pulse">🔥</span>
                    <div class="flex flex-col">
                        <span class="font-['Press_Start_2P'] text-[10px] sm:text-xs text-inferno tracking-wider text-glow">
                            REALTRONO
                        </span>
                        <span class="text-[8px] text-inferno/40 tracking-widest hidden sm:block">
                            EL TRONO MÁS PELIGROSO
                        </span>
                    </div>
                </a>
                
                <!-- CODEC ID -->
                <div class="flex items-center gap-3">
                    <div class="hidden sm:flex flex-col items-end">
                        <span class="text-[8px] text-inferno/40 tracking-widest">CODEC</span>
                        <span class="text-sm font-bold text-glow tabular-nums text-inferno">v2.0</span>
                    </div>
                    <div class="w-2 h-2 bg-inferno-ember rounded-full animate-pulse shadow-[0_0_10px_var(--color-inferno)]"></div>
                </div>
            </div>
        </header>

		<div class="relative z-10">
			<slot />
		</div>
        
        <!-- FOOTER -->
        <footer class="relative z-10 w-full border-t border-inferno/20 mt-12 py-6 px-4">
            <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
                <div class="flex items-center gap-2">
                    <span class="text-lg">🔥</span>
                    <span class="font-['Press_Start_2P'] text-[8px] text-inferno/60">REALTRONO</span>
                </div>
                <p class="text-[10px] text-inferno/40 text-center">
                    "El banquillo del Real Madrid es el más difícil del mundo"
                </p>
                <div class="flex gap-4">
                    <a href="#" class="text-inferno/40 hover:text-inferno text-xs transition-colors">𝕏</a>
                    <a href="#" class="text-inferno/40 hover:text-inferno text-xs transition-colors">IG</a>
                    <a href="#" class="text-inferno/40 hover:text-inferno text-xs transition-colors">YT</a>
                </div>
            </div>
        </footer>
	</body>
</html>
