---
import TenureTimer from './TenureTimer';
import AudioSystem from './AudioSystem';

interface Props {
  coachImage: string;
  opponentImage: string;
  coachName: string;
  opponentName: string;
  statusLevel: number;
  coachStartDate: string;
  matchDate: string;
  homeTeam: { name: string; logo: string };
  awayTeam: { name: string; logo: string };
}

const { coachImage, opponentImage, coachName, opponentName, statusLevel, coachStartDate, matchDate, homeTeam, awayTeam } = Astro.props;

// Frequency Bar Calculation (Visual only)
const frequency = (140.00 + (statusLevel / 100)).toFixed(2);
---

<div class="w-full max-w-4xl mx-auto p-2 sm:p-4 flex flex-col items-center min-h-screen">
    
    <!-- TOP BAR (PTT) -->
    <div class="w-full flex justify-between items-end border-b-2 border-inferno/40 pb-2 mb-6 opacity-90 px-2 relative">
       <div class="flex flex-col gap-1">
          <div class="flex items-center gap-2">
             <div class="w-2 h-2 bg-inferno-ember animate-pulse"></div>
             <span class="text-xs md:text-sm tracking-[0.3em] font-bold text-inferno">PTT CALL...</span>
          </div>
          <AudioSystem client:load />
       </div>
       <div class="flex flex-col items-end shrink-0">
          <span class="text-[8px] sm:text-[10px] md:text-xs tracking-[0.2em] text-inferno/60 mb-0.5 sm:mb-1">TUNER</span>
          <span class="text-xl sm:text-2xl md:text-5xl font-bold tracking-widest text-glow tabular-nums text-inferno">{frequency}</span>
       </div>
       
       <!-- Frequency Visualizer -->
       <div class="absolute -bottom-[2px] left-0 w-full flex items-end gap-0.5 h-1 overflow-hidden">
          {Array.from({ length: 40 }).map((_, i) => (
             <div 
                class="flex-1 bg-inferno/30 animate-frequency" 
                style={`height: ${Math.random() * 100}%; animation-delay: ${i * 0.05}s;`}
             ></div>
          ))}
       </div>
    </div>

    <!-- MAIN VERTICAL STACK -->
    <div class="w-full flex flex-col gap-6">
        
        <!-- BLOCK 1: COACH (HERO) -->
        <div class="w-full aspect-video relative border-y-2 border-inferno bg-black group overflow-hidden shadow-2xl">
             <!-- HUD BARS (Top Overlay) -->
             <div class="absolute top-4 left-4 z-20 flex flex-col gap-2">
                <!-- LIFE BAR -->
                <div class="flex items-center gap-2 sm:gap-3">
                    <span class="text-black font-mono text-[8px] sm:text-xs font-bold tracking-wider bg-inferno px-1.5 sm:px-2 py-0.5 border border-inferno">LIFE</span>
                    <div class="w-24 sm:w-64 h-2 sm:h-3 bg-black border border-inferno/40 relative overflow-hidden">
                        <div class="h-full bg-inferno absolute left-0 top-0 transition-all duration-1000 ease-out" style={`width: ${100 - statusLevel}%; shadow: 0 0 10px var(--color-inferno);`}>
                            <div class="absolute inset-0 flex">
                                {Array.from({ length: 32 }).map(() => (
                                    <div class="flex-1 border-r border-black/30"></div>
                                ))}
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="flex items-center gap-2 sm:gap-3">
                    <span class="text-black font-mono text-[8px] sm:text-xs font-bold tracking-wider bg-inferno/60 px-1.5 sm:px-2 py-0.5 border border-inferno/60 uppercase">O2</span>
                    <div class="w-20 sm:w-48 h-1.5 sm:h-2 bg-black border border-inferno/20 relative flex gap-0.5">
                        {Array.from({ length: 15 }).map((_, i) => (
                            <div class={`h-full bg-inferno/40 flex-1 ${i < 10 ? 'opacity-100' : 'opacity-20'}`}></div>
                        ))}
                    </div>
                </div>
             </div>

             <!-- IMAGE -->
             <div class="w-full h-full relative">
                <img 
                    src={coachImage} 
                    class="w-full h-full object-cover transition-all duration-700 brightness-110"
                    style="filter: grayscale(30%) sepia(80%) hue-rotate(-10deg) saturate(200%) brightness(0.85) contrast(1.3);"
                />
                <!-- Fire tint overlay -->
                <div class="absolute inset-0 bg-gradient-to-t from-inferno-red/30 via-inferno/10 to-transparent mix-blend-overlay pointer-events-none"></div>
             </div>
            
            <!-- Scanlines -->
            <div class="absolute inset-0 bg-[linear-gradient(rgba(18,16,16,0)_50%,rgba(10,2,0,0.15)_50%)] bg-[length:100%_4px] pointer-events-none z-10 opacity-50"></div>

            <!-- NAME TAG + RESULTS (Bottom Overlay) -->
            <div class="absolute bottom-4 left-4 right-4 z-20 flex justify-between items-end">
                <div class="bg-inferno-bg/90 px-3 py-1.5 sm:px-4 sm:py-2 border-2 border-inferno text-xs sm:text-sm md:text-xl font-bold tracking-[0.2em] text-glow uppercase max-w-[70%] truncate text-inferno">
                    {coachName}
                </div>
                <!-- RECENT RESULTS -->
                <div class="hidden sm:flex flex-col gap-1 bg-inferno-bg/80 px-3 py-2 border border-inferno/40 backdrop-blur-sm">
                     <span class="text-[8px] tracking-[0.2em] text-inferno/60 mb-1">LOGS</span>
                     <slot name="results-mini" />
                </div>
            </div>
        </div>

        <!-- BLOCK 2: TIMER (CENTER) -->
        <div class="w-full py-4 flex flex-col items-center justify-center relative">
             <div class="w-full h-[1px] bg-gradient-to-r from-transparent via-inferno/40 to-transparent mb-4"></div>
             <TenureTimer client:load startDate={coachStartDate} matchDate={matchDate} homeTeam={homeTeam} awayTeam={awayTeam} />
             <div class="w-full h-[1px] bg-gradient-to-r from-transparent via-inferno/40 to-transparent mt-4"></div>
        </div>

        <!-- BLOCK 3: RIVAL (BOTTOM) -->
        <div class="w-full aspect-video relative border-2 border-inferno/20 bg-black overflow-hidden group shadow-lg">
             <!-- RIVAL IMAGE -->
             <img 
                src={opponentImage} 
                class="w-full h-full object-cover group-hover:brightness-90 transition-all duration-500"
                style="filter: grayscale(40%) sepia(60%) hue-rotate(-10deg) saturate(180%) brightness(0.7) contrast(1.2);"
             />
             
             <!-- Scanlines -->
             <div class="absolute inset-0 bg-[linear-gradient(rgba(18,16,16,0)_50%,rgba(10,2,0,0.2)_50%)] bg-[length:100%_2px] pointer-events-none z-10"></div>

             <!-- NAME TAG + RESULTS -->
             <div class="absolute bottom-2 left-2 right-2 md:bottom-4 md:left-4 md:right-4 z-20 flex justify-between items-end">
                 <div class="bg-inferno-bg/90 px-3 py-1 border border-inferno/60 text-xs md:text-lg font-bold tracking-widest text-inferno/80">
                     TARGET: {opponentName}
                 </div>
                 <div class="flex flex-col gap-1 bg-inferno-bg/80 px-2 py-1 border border-inferno/20 backdrop-blur-sm">
                     <slot name="rival-results" />
                 </div>
             </div>
        </div>

    </div>

    <!-- SUBTITLES -->
    <div class="w-full mt-8 border-t-2 border-inferno/40 bg-inferno-bg/40 p-6 font-mono text-sm sm:text-base leading-relaxed text-center relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-[1px] bg-inferno/20 animate-scanline-fast"></div>
        <slot name="subtitles" />
    </div>

</div>

<style>
    @keyframes frequency {
        0%, 100% { height: 20%; opacity: 0.3; }
        50% { height: 100%; opacity: 0.8; }
    }
    .animate-frequency {
        animation: frequency 0.5s ease-in-out infinite;
    }
    
    @keyframes scanline-fast {
        0% { transform: translateY(0); opacity: 0; }
        50% { opacity: 1; }
        100% { transform: translateY(80px); opacity: 0; }
    }
    .animate-scanline-fast {
        animation: scanline-fast 4s linear infinite;
    }
</style>
